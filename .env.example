# Sao chép thành .env.local (KHÔNG commit).
# URL API server tự host (server/). Dev mặc định:
VITE_API_BASE_URL=http://localhost:8787

# Dịch vụ chấm phát âm (speech-eval, Python). Bỏ trống nếu không dùng.
VITE_SPEECH_EVAL_URL=http://localhost:8788

# Dịch vụ đọc từ/câu (Piper TTS). Bỏ trống = same-origin /tts (qua proxy); app tự fallback Web Speech nếu service tắt.
VITE_TTS_URL=
