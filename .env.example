# Sao chép thành .env.local (KHÔNG commit) và điền giá trị thật từ Firebase console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Base URL của Firebase Functions (vd https://us-central1-<project>.cloudfunctions.net)
VITE_FUNCTIONS_BASE_URL=

# Dev: bật để kết nối Firebase Emulator (firebase emulators:start) thay cho project thật.
VITE_USE_EMULATOR=false

# --- Đặt ở Functions config/env, KHÔNG để ở frontend ---
# PEXELS_KEY=
# UNSPLASH_KEY=   (tùy chọn, ảnh dự phòng)
